{
  "name": "kbs-cloud",
  "private": true,
  "version": "0.6.1-alpha.2",
  "type": "module",
  "main": "electron-main.cjs",
  "build": {
    "appId": "com.kbscloud.hub",
    "productName": "KBS Cloud Hub",
    "npmRebuild": false,
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "artifactName": "kbs-cloud-hub.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "kbs-cloud-hub-setup.${ext}"
    },
    "mac": {
      "target": "zip",
      "artifactName": "kbs-cloud-hub.${ext}"
    }
  },
  "scripts": {
    "dev": "concurrently \"node server.cjs\" \"vite\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"node server.cjs\" \"vite\" \"wait-on http://localhost:19000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "cap:sync": "npm run build && npx cap sync",
    "android:init": "npx cap init \"KBS Cloud Hub\" \"com.kbscloud.hub\" --web-dir=dist",
    "android:add": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "package:apk": "export ANDROID_HOME=/home/gemini/android-sdk && export JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64 && export PATH=$PATH:$ANDROID_HOME/platform-tools && npm run android:sync && cd android && ./gradlew assembleDebug && mkdir -p ../out && cp app/build/outputs/apk/debug/app-debug.apk ../out/kbs-cloud-hub.apk",
    "ios:init": "npx cap init \"KBS Cloud Hub\" \"com.kbscloud.hub\" --web-dir=dist",
    "ios:add": "npx cap add ios",
    "ios:sync": "npm run build && npx cap sync ios",
    "release": "node ../scripts/release.js"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.0.0",
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
